# Docker environment variables
# Copy this file to .env and fill in your values before running 'docker compose up'

# PostgreSQL password for the database container
POSTGRES_PASSWORD=your_strong_password_here

# JWT secret for signing auth tokens (use a long random string)
JWT_SECRET=your_jwt_secret_here

# The IP or domain of the machine running docker (used by frontend and QR codes)
# For local development: use your local network IP (e.g., 192.168.1.13)
# For production: use your public domain (e.g., https://app.yoursite.com)
NEXT_PUBLIC_API_URL=http://192.168.1.13:3001
NEXT_PUBLIC_APP_URL=http://192.168.1.13:3000
